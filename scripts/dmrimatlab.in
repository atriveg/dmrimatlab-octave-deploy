#!/usr/bin/env -S @OCTAVE_EXE_PATH@ --no-gui --no-window-system -q
addpath('@TOOLBOX_ROOT_PATH@');
addpath('@SCRIPTS_INSTALL_PATH@');

#   Note that when Octave is started from an executable script, the built-in function argv returns a cell array containing the command line arguments passed to the executable Octave script, not the arguments passed to the Octave interpreter on the ‘#!’ line of the script. For example, the following program will reproduce the command line that was used to execute the script, not ‘-qf’.
#
#    #! /bin/octave -qf
#    printf ("%s", program_name ());
#    arg_list = argv ();
#    for i = 1:nargin
#      printf (" %s", arg_list{i});
#    endfor
#    printf ("\n");

setup__DMRIMatlab_toolbox('quiet',true,'nographics',true);

function print_dmrimatlab_help
  warning('off','Octave:data-file-in-path');
  fid = fopen('dmrimatlab.help');
  str = fgets(fid);
  while( ischar(str) )
    fprintf(1,'%s',str);
    str = fgets(fid);
  end
  fclose(fid);
end

nargs = nargin;
args  = argv();
switch(nargs)
  case 0
    print_dmrimatlab_help;
  case 1
    if(   strcmp( strtrim(argv{1}), 'help' )   )
      print_dmrimatlab_help;
    else
      feval(argv{1});
    end
  otherwise
    if(   strcmp( strtrim(argv{1}), 'help' )   )
      help(argv{2})
    else
      cmd    = strtrim(args{1});
      cmdstr = cmd;
      if( (length(cmd)>0) && (cmd(1)=='@') )
        cmd = str2func(cmd);
      end
      args = args(2:end);
      [args,gargs] = dmrimatlab_parse_cmd_args(args);
      [args,niihdr] = dmrimatlab_interpret_cmd_args(args,cmdstr,gargs);
      [args,outs] = dmrimatlab_unroll_cmd_args(args);
      fouts = cell(1,length(outs));
      [fouts{:}] = feval(cmd,args{:});
      dmrimatlab_save_cmd_args(outs,fouts,niihdr);
    end
end
